{
  "name": "cmis-portable",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicación de escritorio para configurar y ejecutar sincronización CMIS portable.",
  "main": "src/CmisPortable.App/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/CmisPortable.Tests/*.test.js",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "keywords": [
    "cmis",
    "sync",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.2.4",
    "electron-builder": "^26.8.1"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.cmisportable.app",
    "productName": "CmisPortable",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
